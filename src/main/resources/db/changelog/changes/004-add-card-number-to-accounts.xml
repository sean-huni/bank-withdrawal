<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-add-card-number-to-accounts" author="sean">
        <addColumn tableName="accounts">
            <column name="card_number" type="VARCHAR(16)"/>
        </addColumn>
        <!-- Deterministic, Luhn-valid demo cards so the FE demo survives DB reseeds. -->
        <update tableName="accounts">
            <column name="card_number" value="4539148803436467"/>
            <where>holder_name = 'Alice'</where>
        </update>
        <update tableName="accounts">
            <column name="card_number" value="6011000990139424"/>
            <where>holder_name = 'Bob'</where>
        </update>
        <addNotNullConstraint tableName="accounts" columnName="card_number" columnDataType="VARCHAR(16)"/>
        <rollback>
            <dropColumn tableName="accounts" columnName="card_number"/>
        </rollback>
    </changeSet>

    <changeSet id="004-unique-card-number" author="sean">
        <createIndex tableName="accounts" indexName="uk_accounts_card_number" unique="true">
            <column name="card_number"/>
        </createIndex>
        <rollback>
            <dropIndex tableName="accounts" indexName="uk_accounts_card_number"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
