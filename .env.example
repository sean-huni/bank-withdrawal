# ENV files should not be added to git, this is just a skeleton to build upon
# Copy to `.env` (gitignored) for personal local overrides — auto-loaded by the app
# (spring.config.import), exported as real env vars by `./gradlew bootRun`/`bootTestRun`,
# AND read natively by docker compose. Every key is optional; the application starts
# with sensible local defaults when this file is absent.
# Precedence: yml default < .env < real environment variable.

# --- Spring profile ---
# dev = OTLP export to the local Grafana LGTM container + the startup DEV TEST DATA
# banner (Swagger cheat sheet: account/transaction ids, sortable fields, fresh
# Idempotency-Key). Needs a real env var, hence the Gradle export above.
SPRING_PROFILES_ACTIVE=dev

# --- Server ---
#SERVER_PORT=8080

# --- API endpoints (at the port above; {api-version} resolved by path-segment versioning) ---
#   POST http://localhost:8080/api/v1/accounts/{accountId}/withdrawals     (Idempotency-Key header required)
#   POST http://localhost:8080/api/v1/accounts/{accountId}/deposits        (Idempotency-Key header required)
#   GET  http://localhost:8080/api/v1/accounts/{accountId}/transactions
#   GET  http://localhost:8080/api/v1/accounts/{accountId}/transactions/{transactionId}
# Management (public — security descoped):
#   GET  http://localhost:8080/actuator/health | /actuator/metrics | /actuator/caches
# OpenAPI (springdoc 3.x):
#   UI:   http://localhost:8080/swagger-ui/index.html
#   Spec: http://localhost:8080/v3/api-docs

# --- AWS / LocalStack (app.aws.*) ---
#AWS_REGION=us-east-1
#AWS_ENDPOINT=http://localhost:4566
#AWS_ACCESS_KEY=test
#AWS_SECRET_KEY=test
#WITHDRAWAL_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:bank-withdrawal-events

# --- Observability (dev profile) ---
#OTLP_BASE_URL=http://localhost:4318
# UIs from the compose grafana-lgtm container, linked in the dev banner:
#GRAFANA_URL=http://localhost:3000
#PROMETHEUS_URL=http://localhost:9090

# --- ATM frontend (fe-bank-withdrawal) — surfaced in the dev banner ---
#FRONTEND_URL=http://localhost:5173
#FRONTEND_REPO_URL=https://github.com/sean-huni/fe-bank-withdrawal

# --- Passkeys / WebAuthn (atm.passkey.*) — the passkey-enabled ATM ---
# rp-id is the registrable domain credentials are scoped to; origins is the comma-separated
# list of exact browser origins allowed to run the ceremony. localhost is browsers' only
# non-HTTPS exception; production must use the apex domain + HTTPS origins.
#   Ceremony endpoints (at SERVER_PORT):
#     POST /webauthn/register/options   (enrol — requires an authenticated ATM session)
#     POST /webauthn/register           (enrol — completes attestation)
#     POST /webauthn/authenticate/options  (return visit — public, username-less)
#     POST /login/webauthn              (return visit — discoverable-credential login)
#   ATM session bootstrap (card+PIN → authenticated session):
#     POST /api/v1/atm/session  -d '{"cardNumber":"4539148803436467","pin":"1234"}'
#PASSKEY_RP_ID=localhost
#PASSKEY_RP_NAME=Bank Withdrawal ATM
#PASSKEY_ORIGINS=http://localhost:5173

# --- docker compose: PostgreSQL ---
#POSTGRES_DB=bank
#POSTGRES_USER=bank
#POSTGRES_PASSWORD=bank
